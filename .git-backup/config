[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/vanessa-dev/champion-challenges.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "feat-unit-tests"]
	remote = origin
	merge = refs/heads/feat-unit-tests
	vscode-merge-base = origin/feat-unit-tests
